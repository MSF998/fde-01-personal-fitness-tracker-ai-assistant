# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# OpenRouter API key — used server-side only (docs/system-design.md decision).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional — overrides the default model (docs/build-roadmap.md §2's decision).
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
